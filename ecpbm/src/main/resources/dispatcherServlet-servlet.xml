<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context
        http://www.springframework.org/schema/context/spring-context.xsd
        http://www.springframework.org/schema/mvc
        http://www.springframework.org/schema/mvc/spring-mvc.xsd">

    <!-- 1. 扫描Controller层 -->
    <context:component-scan base-package="com.ecpbm.controller">
        <context:include-filter type="annotation" expression="org.springframework.stereotype.Controller"/>
    </context:component-scan>

    <!-- 2. 开启SpringMVC注解驱动（支持@RequestMapping、JSON返回等） -->
    <mvc:annotation-driven>
        <mvc:message-converters register-defaults="true">
            <!-- 解决字符串/HTML中文乱码 -->
            <bean class="org.springframework.http.converter.StringHttpMessageConverter">
                <property name="supportedMediaTypes">
                    <list>
                        <value>text/html;charset=UTF-8</value>
                        <value>text/plain;charset=UTF-8</value>
                    </list>
                </property>
            </bean>

            <!-- 正确配置JSON消息转换器：MappingJackson2HttpMessageConverter（真正的转换器） -->
            <bean class="org.springframework.http.converter.json.MappingJackson2HttpMessageConverter">
                <!-- 内部注入ObjectMapper（JSON序列化工具） -->
                <property name="objectMapper">
                    <bean class="com.fasterxml.jackson.databind.ObjectMapper">
                        <!-- 可选优化：JSON格式化配置（避免返回null字段、日期格式化） -->
<!--                        <property name="serializationInclusion" value="com.fasterxml.jackson.annotation.JsonInclude.Include.NON_NULL"/>-->
                        <property name="dateFormat">
                            <!-- 日期统一格式：yyyy-MM-dd HH:mm:ss -->
                            <bean class="java.text.SimpleDateFormat">
                                <constructor-arg value="yyyy-MM-dd HH:mm:ss"/>
                            </bean>
                        </property>
                    </bean>
                </property>
                <!-- 支持JSON媒体类型 -->
                <property name="supportedMediaTypes">
                    <list>
                        <value>application/json;charset=UTF-8</value>
                        <value>application/javascript;charset=UTF-8</value>
                    </list>
                </property>
            </bean>
        </mvc:message-converters>
    </mvc:annotation-driven>

    <!-- 3. 静态资源放行（EasyUI、JS、CSS、图片等） -->
    <mvc:default-servlet-handler/>

    <!-- 4. 视图解析器（JSP页面） -->
    <bean class="org.springframework.web.servlet.view.InternalResourceViewResolver">
        <property name="prefix" value=""/>  <!-- 页面在webapp根目录，前缀为空 -->
        <property name="suffix" value=".jsp"/>
    </bean>

    <!-- 5. 文件上传解析器（适配之前的商品图片上传功能） -->
    <bean id="multipartResolver" class="org.springframework.web.multipart.commons.CommonsMultipartResolver">
        <property name="defaultEncoding" value="UTF-8"/>
        <property name="maxUploadSize" value="10485760"/>  <!-- 最大上传文件大小：10MB -->
        <property name="maxInMemorySize" value="4096"/>
    </bean>


</beans>